# =============================================================================
#  Gitea — production environment
#  Copy to .env and fill in, or run ./setup.sh to generate it interactively.
#  NEVER commit the real .env — it holds secrets.
# =============================================================================

#  --- Gitea container ---
CONTAINER_NAME=gitea

#  Web UI port (host side). Behind a reverse proxy this is bound to localhost
#  only (see GITEA_WEB_BIND) and the proxy talks to it.
GITEA_FRONTEND_PORT=8989
#  Host interface the web port binds to:
#    127.0.0.1 = loopback only — use ONLY if the proxy/tunnel runs on THIS host
#    0.0.0.0   = all interfaces — required if cloudflared/proxy is a Docker
#                container or on another machine (it reaches the host via LAN IP),
#                or if you want LAN browser access. On a home-NAT server this is
#                still LAN-only, not internet-exposed.
#  Default 0.0.0.0 works for the common case (containerized cloudflared). Switch
#  to 127.0.0.1 only when the proxy runs on THIS host and you want it locked down.
GITEA_WEB_BIND=0.0.0.0
#  Git-over-SSH port (host side). Exposed publicly so you can push.
GITEA_SSH_PORT=222

#  Data volumes on the host
GITEA_VOLUME=/gitea
GITEA_DB_VOLUME=/gitea/mysql

#  --- Public address ---
#  The domain your instance is served on (clone URLs, cookies, redirects).
#  This is what the Cloudflare Tunnel / proxy serves over HTTPS.
GITEA_DOMAIN=git.example.com
#  Host shown in SSH clone URLs. SSH does NOT go through the tunnel, so this
#  must be reachable directly — your server's LAN IP (SSH kept LAN-only) or a
#  DNS-only record pointing at the server. setup.sh defaults it to the LAN IP.
GITEA_SSH_DOMAIN=192.168.1.50
#  Full external URL.
#    Behind an HTTPS proxy:          https://git.example.com/
#    Direct HTTP on a custom port:   http://git.example.com:8989/
GITEA_ROOT_URL=https://git.example.com/

#  --- Access policy ---
#  Self-registration is DISABLED and the install wizard is LOCKED in
#  docker-compose.yml (fixed production posture). This is the one toggle you
#  may want to change:
#    false = anyone can VIEW your public repos, read-only   <-- your use case
#    true  = visitors must sign in even to view anything
GITEA_REQUIRE_SIGNIN_VIEW=false

#  --- Security secrets ---
#  Generate with ./setup.sh. Do NOT ship the example values.
GITEA__security__SECRET_KEY=changeme-run-setup.sh
GITEA__security__INTERNAL_TOKEN=changeme-run-setup.sh

#  --- Database ---
GITEA__database__DB_TYPE=mysql
GITEA__database__HOST=db:3306
GITEA__database__NAME=gitea
GITEA__database__USER=gitea
GITEA__database__PASSWD=changeme            # must equal MYSQL_PASSWORD below

MYSQL_ROOT_PASSWORD=changeme
MYSQL_USER=gitea                            # must equal GITEA__database__USER
MYSQL_PASSWORD=changeme                     # must equal GITEA__database__PASSWD
MYSQL_DATABASE=gitea                        # must equal GITEA__database__NAME

#  --- Actions runner (optional) ---
RUNNER_CONTAINER_NAME=gitea-runner
RUNNER_NAME=main-runner
RUNNER_GITEA_URL=http://<server-ip>:8989    # URL the runner uses to reach Gitea (server IP, not localhost)
RUNNER_TOKEN=                               # Gitea Admin Panel -> /admin/runners -> Create Runner

# Which host paths deploy workflows may mount into job containers is configured
# in config.yaml (container.valid_volumes) — copy config.yaml.example first.
